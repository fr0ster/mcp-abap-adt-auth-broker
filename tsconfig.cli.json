{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"]
  },
  "include": ["bin/mcp-auth.ts", "bin/mcp-sso.ts", "src/cli/parseArgs.ts"],
  "exclude": ["node_modules", "dist"]
}
