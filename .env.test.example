# Configuration template for the public-client integration test.
# Copy to `.env.test` (gitignored) and fill in values for your target system.
# Used by `npm run test:integration:public-client`.

# Base URL of the ABAP system (BTP `endpoints.abap` from the service key,
# typically https://<uuid>.abap.<region>.hana.ondemand.com).
TEST_ABAP_URL=https://<uuid>.abap.<region>.hana.ondemand.com

# Base URL of the XSUAA tenant (`uaa.url` from the service key).
TEST_UAA_URL=https://<tenant>.authentication.<region>.hana.ondemand.com

# Public OAuth client_id with localhost redirect registered (`uaa.clientid`
# from the service key works if the registration allows PKCE).
TEST_CLIENT_ID=sb-xs-...|xsuaa-abapcp-prod-<region>!b4584
